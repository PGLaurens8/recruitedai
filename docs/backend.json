
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the CareerCraft AI application, storing their profile information, role, and company affiliation.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": {
          "type": "string",
          "enum": ["Candidate", "Recruiter", "Admin", "Sales", "Developer"]
        },
        "companyId": { "type": "string" },
        "plan": { "type": "string" },
        "onboardingStep": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "companyId", "plan", "createdAt", "updatedAt"]
    },
    "Company": {
      "title": "Company",
      "type": "object",
      "description": "An agency or organization profile.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "website": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "premium", "enterprise"] },
        "address": { "type": "string" }
      }
    },
    "Candidate": {
      "title": "Candidate",
      "type": "object",
      "description": "A candidate record within an agency's database.",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string" },
        "aiScore": { "type": "number" },
        "currentJob": { "type": "string" },
        "currentCompany": { "type": "string" },
        "appliedForJobId": { "type": "string" },
        "avatar": { "type": "string" }
      }
    },
    "Job": {
      "title": "Job",
      "type": "object",
      "description": "A job posting or specification.",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "title": { "type": "string" },
        "salary": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string" },
        "approval": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "A client company hiring via the agency.",
      "properties": {
        "id": { "type": "string" },
        "companyId": { "type": "string" },
        "name": { "type": "string" },
        "contactName": { "type": "string" },
        "contactEmail": { "type": "string" },
        "status": { "type": "string" },
        "logo": { "type": "string" }
      }
    },
    "ModelInfo": {
      "title": "ModelInfo",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "displayName": { "type": "string" },
        "description": { "type": "string" },
        "supportedGenerationMethods": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ModelRegistry": {
      "title": "ModelRegistry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "models": { "type": "array", "items": { "$ref": "#/backend/entities/ModelInfo" } },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "users/{userId}",
        "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" }, "description": "User profiles." }
      },
      {
        "path": "companies/{companyId}",
        "definition": { "entityName": "Company", "schema": { "$ref": "#/backend/entities/Company" }, "description": "Company metadata." }
      },
      {
        "path": "companies/{companyId}/candidates/{candidateId}",
        "definition": { "entityName": "Candidate", "schema": { "$ref": "#/backend/entities/Candidate" }, "description": "Agency candidate pool." }
      },
      {
        "path": "companies/{companyId}/jobs/{jobId}",
        "definition": { "entityName": "Job", "schema": { "$ref": "#/backend/entities/Job" }, "description": "Agency job postings." }
      },
      {
        "path": "companies/{companyId}/clients/{clientId}",
        "definition": { "entityName": "Client", "schema": { "$ref": "#/backend/entities/Client" }, "description": "Agency clients." }
      },
      {
        "path": "modelRegistry/latest",
        "definition": { "entityName": "ModelRegistry", "schema": { "$ref": "#/backend/entities/ModelRegistry" }, "description": "AI model list." }
      }
    ]
  }
}
