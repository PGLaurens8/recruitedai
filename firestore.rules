
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasUnchangedProtectedProfileFields() {
      return request.resource.data.role == resource.data.role
        && request.resource.data.companyId == resource.data.companyId
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.email == resource.data.email
        && request.resource.data.id == resource.data.id;
    }

    function isAllowedSelfSignupRole() {
      return request.resource.data.role == 'Recruiter' || request.resource.data.role == 'Candidate';
    }

    /** @description Checks if the user is a Developer. */
    function isDeveloper() {
      return isSignedIn() && getUserData().role == 'Developer';
    }

    /** @description Checks if user belongs to a specific company. */
    function belongsToCompany(companyId) {
      return isSignedIn() && getUserData().companyId == companyId;
    }

    /** @description Checks if user has a role that can manage company data. */
    function canManageCompany() {
      let role = getUserData().role;
      return role == 'Admin' || role == 'Recruiter' || role == 'Sales' || role == 'Developer';
    }

    // --- COLLECTION RULES ---

    /** Root User profile document */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isDeveloper();
      allow create: if isOwner(userId)
        && request.resource.data.id == request.auth.uid
        && request.resource.data.companyId == request.auth.uid
        && isAllowedSelfSignupRole();
      allow update: if (isOwner(userId) && hasUnchangedProtectedProfileFields()) || isDeveloper();
      allow delete: if isDeveloper();
    }

    /** Model Registry - Public read, write restricted to Developers */
    match /modelRegistry/latest {
      allow get: if true;
      allow write: if isDeveloper();
    }

    /** Company Shared Data */
    match /companies/{companyId} {
      allow read: if belongsToCompany(companyId) || isDeveloper();
      allow write: if (belongsToCompany(companyId) && canManageCompany()) || isDeveloper();

      /** Nested multitenant collections (Candidates, Jobs, Clients) */
      match /{allSubcollections=**} {
        allow read, write: if belongsToCompany(companyId) && canManageCompany() || isDeveloper();
      }
    }

    /** 
     * User Private Data Legacy Support
     */
    match /users/{userId}/{allSubcollections=**} {
      allow read, write: if isOwner(userId) || isDeveloper();
    }
  }
}
