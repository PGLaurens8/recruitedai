/**
 * CareerCraft AI Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model designed for a multi-tenant SaaS application. 
 * Each user acts as an isolated tenant where their data is logically separated by their unique 
 * Firebase Authentication UID. Access is primarily governed by path-based ownership.
 *
 * Data Structure:
 * - Private User Data: Nested under `/users/{userId}/...`. Only the authenticated owner 
 *   whose UID matches `{userId}` can access this data.
 * - Public Data: Specific entities like `OnlineResume` and `LinkTree` have public mirrors 
 *   under `/onlineResumesPublic/` and `/linkTreesPublic/`. These are readable by anyone 
 *   if the `isPublished` flag is true, but only writable by the original owner.
 *
 * Key Security Decisions:
 * - Authorization Independence: Documents contain denormalized `userId` fields to allow 
 *   fast, non-recursive security checks that don't rely on `get()` calls to parent documents.
 * - Structural Segregation: Private settings and public displays are separated into 
 *   different collections to prevent accidental data exposure and simplify list queries.
 * - Prototyping Flexibility: While authorization is strictly enforced based on ownership, 
 *   the specific schema (data types and shapes) is not enforced to allow for rapid development.
 *
 * Denormalization for Authorization:
 * - The `userId` is present on all user-owned documents.
 * - The `isPublished` flag is present on all public-facing documents.
 * - This allows for simple rules like `allow read: if resource.data.isPublished == true`.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document already exists. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** @description Validates that the userId in the data matches the userId in the path. */
    function isPathConsistent(userId) {
      return request.resource.data.userId == userId;
    }

    /** @description Validates that the userId field remains unchanged during updates. */
    function isUserIdImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the core UserProfile document.
     * @path /users/{userId}
     * @allow (get, list, create, update) if UID matches userId.
     * @deny (delete) always (profiles should be deactivated, not deleted).
     * @principle Self-creation and ownership.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if false; // Profiles are permanent for audit/billing.

      /**
       * @description User's collection of resumes.
       * @path /users/{userId}/resumes/{resumeId}
       * @allow (all) if user owns the path and data matches the owner.
       * @deny (create) if userId in data does not match the path.
       */
      match /resumes/{resumeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isPathConsistent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);

        /**
         * @description Work experiences associated with a resume.
         */
        match /workExperiences/{workExperienceId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update: if isExistingOwner(userId);
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Education entries associated with a resume.
         */
        match /educationEntries/{educationId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update: if isExistingOwner(userId);
          allow delete: if isExistingOwner(userId);
        }

        /**
         * @description Skills associated with a resume.
         */
        match /skills/{skillId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update: if isExistingOwner(userId);
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Metadata for files uploaded by the user.
       * @path /users/{userId}/uploadedFiles/{fileId}
       */
      match /uploadedFiles/{fileId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isPathConsistent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Job specifications provided by the user.
       * @path /users/{userId}/jobSpecifications/{jobSpecId}
       */
      match /jobSpecifications/{jobSpecId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isPathConsistent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Log of AI processing requests.
       * @path /users/{userId}/aiRequests/{requestId}
       */
      match /aiRequests/{requestId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isPathConsistent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Record of user payments.
       * @path /users/{userId}/payments/{paymentId}
       */
      match /payments/{paymentId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isPathConsistent(userId);
        allow update: if false; // Payments are immutable.
        allow delete: if false; // Payments cannot be deleted.
      }

      /**
       * @description Private settings for an online resume.
       * @path /users/{userId}/onlineResumes/{onlineResumeId}
       */
      match /onlineResumes/{onlineResumeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isPathConsistent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Private settings for a LinkTree.
       * @path /users/{userId}/linkTrees/{linkTreeId}
       */
      match /linkTrees/{linkTreeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && isPathConsistent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Public mirror of Online Resumes.
     * @path /onlineResumesPublic/{slug}
     * @allow (read) if the resume is published.
     * @allow (write) if authenticated user is the owner (userId field).
     * @principle Public read with owner-only writes.
     */
    match /onlineResumesPublic/{slug} {
      allow get, list: if resource.data.isPublished == true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @description Public mirror of LinkTrees.
     * @path /linkTreesPublic/{slug}
     * @allow (read) if the LinkTree is published.
     * @allow (write) if authenticated user is the owner (userId field).
     */
    match /linkTreesPublic/{slug} {
      allow get, list: if resource.data.isPublished == true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}