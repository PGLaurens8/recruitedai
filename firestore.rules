
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CAREERCRAFT AI - FIRESTORE SECURITY RULES
     * Implements multitenancy and role-based access control.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is a Developer (via their profile document). */
    function isDeveloper() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Developer';
    }

    /** @description Checks if the user has a specific role. */
    function hasRole(role) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // --- COLLECTION RULES ---

    /** Root User profile document */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if isOwner(userId);
    }

    /** Model Registry - Public read for transparency, write restricted to Developers */
    match /modelRegistry/latest {
      allow get: if true;
      allow write: if isDeveloper();
    }

    /** 
     * User Private Data
     * All sub-resources are nested under /users/{userId} to ensure path-based ownership.
     */
    match /users/{userId}/{allSubcollections=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
