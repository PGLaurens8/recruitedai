
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is a Developer. */
    function isDeveloper() {
      return isSignedIn() && getUserData().role == 'Developer';
    }

    /** @description Checks if user belongs to a specific company. */
    function belongsToCompany(companyId) {
      return isSignedIn() && getUserData().companyId == companyId;
    }

    /** @description Checks if user has a role that can manage company data. */
    function canManageCompany() {
      let role = getUserData().role;
      return role == 'Admin' || role == 'Recruiter' || role == 'Sales' || role == 'Developer';
    }

    // --- COLLECTION RULES ---

    /** Root User profile document */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isSignedIn();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /** Model Registry - Public read, write restricted to Developers */
    match /modelRegistry/latest {
      allow get: if true;
      allow write: if isDeveloper();
    }

    /** Company Shared Data */
    match /companies/{companyId} {
      allow read: if belongsToCompany(companyId);
      allow write: if belongsToCompany(companyId) && canManageCompany();

      /** Nested multitenant collections */
      match /candidates/{candidateId} {
        allow read, write: if belongsToCompany(companyId) && canManageCompany();
      }
      match /jobs/{jobId} {
        allow read, write: if belongsToCompany(companyId) && canManageCompany();
      }
      match /clients/{clientId} {
        allow read, write: if belongsToCompany(companyId) && canManageCompany();
      }
    }

    /** 
     * User Private Data Legacy Support
     */
    match /users/{userId}/{allSubcollections=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
