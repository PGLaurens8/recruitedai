    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/smoke.spec.ts --project=chromium",
    "security:secrets": "sh -c 'PATTERN=\"(sk-[A-Za-z0-9]{20,}|AIza[0-9A-Za-z_-]{35}|AKIA[0-9A-Z]{16}|BEGIN PRIVATE KEY|xox[baprs]-)\"; if command -v rg >/dev/null 2>&1; then rg -n --hidden --glob \"!.git\" --glob \"!node_modules\" --glob \"!.env*\" --glob \"!package.json\" --glob \"!docs/api-key-rotation-and-secret-hygiene.md\" \"$PATTERN\"; code=$?; elif command -v grep >/dev/null 2>&1; then grep -RInE --binary-files=without-match --exclude-dir=.git --exclude-dir=node_modules --exclude=.env --exclude=.env.* --exclude=package.json --exclude=api-key-rotation-and-secret-hygiene.md \"$PATTERN\" .; code=$?; else echo \"Neither rg nor grep found\" >&2; exit 127; fi; if [ $code -eq 0 ]; then exit 1; elif [ $code -eq 1 ]; then exit 0; else exit $code; fi'"
  },
